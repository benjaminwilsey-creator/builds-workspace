# Rapid2 v1.4 — Required environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Kraken API credentials (required for live bot.py only — not for paper_bot.py --dry-run)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Telegram live bot token (required for bot.py — not for paper_bot.py --dry-run)
TELEGRAM_TOKEN=

# Telegram paper bot token (required for paper_bot.py full loop — separate from live)
PAPER_TELEGRAM_TOKEN=

# Telegram chat ID (required for both bots)
TELEGRAM_CHAT_ID=

# Paper trading starting balance in USD (optional — defaults to 90)
PAPER_STARTING_USD=90
