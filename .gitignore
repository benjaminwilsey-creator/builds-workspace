# Subprojects with their own git repos — exclude them here
Rapid2/
# Booksmut has no separate repo — tracked in builds-workspace

# Claude Desktop Skills folder on Desktop (ephemeral output)
# Never commit secrets or credentials
*.env
.env.*
!.env.example
*credentials*.json

# Windows / OS noise
Thumbs.db
Desktop.ini
.DS_Store

# LibreOffice lock files (created when a file is open, never commit)
.~lock.*

# Python cache
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# VS Code user settings (keep workspace file, exclude user-specific)
.vscode/settings.json
Architect/
