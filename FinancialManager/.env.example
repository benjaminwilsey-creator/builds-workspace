# ── Plaid (bank account connection) ──────────────────────────────────────────
# Get these from https://dashboard.plaid.com after creating a free developer account.
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=development          # sandbox | development | production

# Generated after you connect your Truist account via Plaid Link.
# Run: python scripts/plaid_setup.py
PLAID_ACCESS_TOKEN=your_access_token_here

# ── Slack ─────────────────────────────────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps
# Grant scope: chat:write
# Install to your workspace and copy the Bot User OAuth Token.
SLACK_BOT_TOKEN=xoxb-your-token-here

# The Slack channel ID (not name) to post finance alerts.
# Right-click the channel in Slack → View channel details → copy the ID at the bottom.
SLACK_FINANCE_CHANNEL=C0XXXXXXXXX

# ── Scheduler ────────────────────────────────────────────────────────────────
# What time (24h) to run the daily bill check. Default: 8:00 AM.
CHECK_HOUR=8
CHECK_MINUTE=0
